    {
      "id": "txt_security_states",
      "type": "text",
      "x": 1212,
      "y": 738,
      "width": 640,
      "height": 132,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1131,
      "version": 1,
      "versionNonce": 1131,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Reglas de seguridad de puerta\n\n- closed + locked: door_secure -> puede ser optimal\n- closed + unlocked: door_unlocked_closed -> warning\n- open despues de unlock valido: door_open_authorized -> warning\n- open sin unlock valido: door_open_forced -> critical\n- error de bloqueo: door_lock_error -> critical\n\nEventos de acceso: none, granted, denied, timeout, forced_open, manual_lock",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Reglas de seguridad de puerta\n\n- closed + locked: door_secure -> puede ser optimal\n- closed + unlocked: door_unlocked_closed -> warning\n- open despues de unlock valido: door_open_authorized -> warning\n- open sin unlock valido: door_open_forced -> critical\n- error de bloqueo: door_lock_error -> critical\n\nEventos de acceso: none, granted, denied, timeout, forced_open, manual_lock",
      "lineHeight": 1.25,
      "baseline": 126
    },

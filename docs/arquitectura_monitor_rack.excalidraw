      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "API REST FastAPI\napi-rest/\n\nConsulta InfluxDB:\nGET /api/rack/status\nGET /api/rack/modes\nGET /api/actuators\n\nPublica comandos MQTT:\nPUT /api/rack/mode\nPOST /api/door/unlock\nPOST /api/door/lock\nPOST /api/fan/auto\nPOST /api/fan/manual",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API REST FastAPI\napi-rest/\n\nConsulta InfluxDB:\nGET /api/rack/status\nGET /api/rack/modes\nGET /api/actuators\n\nPublica comandos MQTT:\nPUT /api/rack/mode\nPOST /api/door/unlock\nPOST /api/door/lock\nPOST /api/fan/auto\nPOST /api/fan/manual",
      "lineHeight": 1.25,
      "baseline": 174

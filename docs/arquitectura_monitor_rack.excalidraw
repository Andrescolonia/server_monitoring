    {
      "id": "txt_topics",
      "type": "text",
      "x": 432,
      "y": 608,
      "width": 646,
      "height": 184,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1121,
      "version": 1,
      "versionNonce": 1121,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "MQTT topics principales\n\nTelemetria ESP32 -> HiveMQ:\n- sensors/dht22/temperature_c, humidity_pct\n- sensors/door/state\n- sensors/mpu6050/position, tilt_deg, vibration_level, pitch_deg, roll_deg\n- status/system, status/reason, status/components/*, status/last_will\n- control/mode\n- actuators/fan/power_pct, actuators/fan/mode, actuators/door_lock/state\n- security/door/state, security/access/last_event\n\nComandos API -> HiveMQ -> ESP32:\n- commands/mode/set\n- commands/door/unlock, commands/door/lock\n- commands/fan/auto, commands/fan/manual",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MQTT topics principales\n\nTelemetria ESP32 -> HiveMQ:\n- sensors/dht22/temperature_c, humidity_pct\n- sensors/door/state\n- sensors/mpu6050/position, tilt_deg, vibration_level, pitch_deg, roll_deg\n- status/system, status/reason, status/components/*, status/last_will\n- control/mode\n- actuators/fan/power_pct, actuators/fan/mode, actuators/door_lock/state\n- security/door/state, security/access/last_event\n\nComandos API -> HiveMQ -> ESP32:\n- commands/mode/set\n- commands/door/unlock, commands/door/lock\n- commands/fan/auto, commands/fan/manual",
      "lineHeight": 1.25,
      "baseline": 178
    },
    {
      "id": "box_security_states",
      "type": "rectangle",
      "x": 1190,
      "y": 720,
      "width": 680,
      "height": 180,
      "angle": 0,
      "strokeColor": "#c92a2a",

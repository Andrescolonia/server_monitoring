        <mxCell id="band_devices" value="Capa de dispositivos" style="swimlane;html=1;rounded=1;fillColor=#e3fafc;strokeColor=#0b7285;fontSize=20;fontStyle=1;startSize=36;horizontal=1;" vertex="1" parent="layer_devices">
          <mxGeometry x="40" y="130" width="2200" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="sensors" value="Sensores fisicos&lt;br&gt;&lt;br&gt;&lt;b&gt;DHT22&lt;/b&gt;&lt;br&gt;Temperatura y humedad&lt;br&gt;DATA GPIO 4&lt;br&gt;Offset temp -5 C, humedad -20%&lt;br&gt;&lt;br&gt;&lt;b&gt;HC-SR04&lt;/b&gt;&lt;br&gt;Puerta abierta/cerrada&lt;br&gt;TRIG GPIO 32, ECHO GPIO 34&lt;br&gt;Divisor de voltaje 5V a 3.3V&lt;br&gt;&lt;br&gt;&lt;b&gt;MPU6050&lt;/b&gt;&lt;br&gt;Posicion, inclinacion y vibracion&lt;br&gt;I2C SDA 21 / SCL 22&lt;br&gt;&lt;br&gt;Fotoresistencia reservada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#0b7285;fontSize=13;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_devices">
          <mxGeometry x="70" y="185" width="350" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="esp32" value="ESP32 Firmware&lt;br&gt;&lt;br&gt;- Lee sensores cada 5 s&lt;br&gt;- Aplica offsets DHT22&lt;br&gt;- Detecta puerta por ultrasonico&lt;br&gt;- Evalua estado general&lt;br&gt;- Gestiona LED RGB&lt;br&gt;- Simula fan y servo&lt;br&gt;- Publica MQTT retained&lt;br&gt;- Recibe comandos MQTT&lt;br&gt;- Last Will: offline_lost_signal_or_power" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edf2ff;strokeColor=#364fc7;fontSize=14;align=left;verticalAlign=top;spacing=10;fontStyle=1;" vertex="1" parent="layer_devices">
          <mxGeometry x="500" y="185" width="360" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="actuators" value="Actuadores&lt;br&gt;&lt;br&gt;&lt;b&gt;LED RGB&lt;/b&gt;&lt;br&gt;R GPIO 25 | G GPIO 26 | B GPIO 27&lt;br&gt;Titileo apagado/color cada 4 s&lt;br&gt;&lt;br&gt;&lt;b&gt;Ventilador&lt;/b&gt;&lt;br&gt;Simulado por consola&lt;br&gt;Auto/manual, potencia 0 a 100%&lt;br&gt;&lt;br&gt;&lt;b&gt;Servo bloqueo&lt;/b&gt;&lt;br&gt;Simulado por consola&lt;br&gt;Bloquear/desbloquear puerta" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebfbee;strokeColor=#2b8a3e;fontSize=13;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_devices">
          <mxGeometry x="940" y="185" width="350" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="rack_box" value="Maqueta del rack&lt;br&gt;&lt;br&gt;- Caja: 16 cm ancho&lt;br&gt;- 10 cm profundo&lt;br&gt;- 32 cm alto&lt;br&gt;- Estado normal: vertical normal&lt;br&gt;- Puerta cerrada y bloqueada&lt;br&gt;- Temperatura en rango del modo activo&lt;br&gt;&lt;br&gt;Identificador: rack01" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#495057;fontSize=13;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_devices">
          <mxGeometry x="1370" y="185" width="330" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="serial_diag" value="Monitor Serial&lt;br&gt;&lt;br&gt;- Diagnostico humano&lt;br&gt;- JSON de telemetria local&lt;br&gt;- Estados simulados de fan/servo&lt;br&gt;- Pruebas de sensores&lt;br&gt;- Verificacion antes de MQTT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9db;strokeColor=#f08c00;fontSize=13;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_devices">
          <mxGeometry x="1780" y="185" width="330" height="170" as="geometry"/>

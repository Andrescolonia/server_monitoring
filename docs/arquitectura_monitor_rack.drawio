        <mxCell id="wifi" value="WiFi + TLS&lt;br&gt;&lt;br&gt;- ESP32 se conecta como cliente WiFi&lt;br&gt;- MQTT sobre puerto 8883&lt;br&gt;- Reconexion periodica&lt;br&gt;- Estado network: online/offline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7048e8;fontSize=13;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_network">

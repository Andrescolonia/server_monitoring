        <mxCell id="control_modes" value="Modos de operacion&lt;br&gt;&lt;br&gt;&lt;b&gt;standard&lt;/b&gt;&lt;br&gt;Temp optima max 32 C&lt;br&gt;Fan base 25%, alerta 60%, critico 100%&lt;br&gt;&lt;br&gt;&lt;b&gt;energy_saving&lt;/b&gt;&lt;br&gt;Temp optima max 34 C&lt;br&gt;Fan base 0%, alerta 40%, critico 80%&lt;br&gt;&lt;br&gt;&lt;b&gt;performance&lt;/b&gt;&lt;br&gt;Temp optima max 28 C&lt;br&gt;Fan base 50%, alerta 80%, critico 100%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9db;strokeColor=#f08c00;fontSize=12;align=left;verticalAlign=top;spacing=10;fontStyle=1;" vertex="1" parent="layer_security">
          <mxGeometry x="540" y="1320" width="380" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="status_policy" value="Politica de estado general&lt;br&gt;&lt;br&gt;optimal&lt;br&gt;- Todo en rango&lt;br&gt;- Puerta segura&lt;br&gt;- MPU vertical normal&lt;br&gt;&lt;br&gt;warning&lt;br&gt;- Temperatura/humedad en alerta&lt;br&gt;- Puerta desbloqueada&lt;br&gt;- Puerta abierta autorizada&lt;br&gt;&lt;br&gt;critical&lt;br&gt;- Apertura no autorizada&lt;br&gt;- Temp/humedad critica&lt;br&gt;- Inclinacion/vibracion critica&lt;br&gt;&lt;br&gt;sensor_error / offline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c92a2a;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_security">

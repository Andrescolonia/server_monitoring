        <mxCell id="observability" value="Observabilidad y diagnostico&lt;br&gt;&lt;br&gt;- status/reason explica el motivo&lt;br&gt;- status/components/* separa causas&lt;br&gt;- last_will detecta perdida de energia/senal&lt;br&gt;- Grafana conserva historicos&lt;br&gt;- Frontend muestra operacion actual&lt;br&gt;- MQTT Explorer valida topicos en vivo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#495057;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_security">

        <mxCell id="bridge" value="Bridge Python&lt;br&gt;bridge-python/&lt;br&gt;&lt;br&gt;- Cliente MQTT subscriber&lt;br&gt;- Escucha monitor-servidores/rack01/#&lt;br&gt;- Convierte payloads&lt;br&gt;- Genera codigos numericos&lt;br&gt;- Escribe puntos en InfluxDB&lt;br&gt;&lt;br&gt;Librerias:&lt;br&gt;paho-mqtt, influxdb-client, dotenv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#e67700;fontSize=13;align=left;verticalAlign=top;spacing=10;fontStyle=1;" vertex="1" parent="layer_data">

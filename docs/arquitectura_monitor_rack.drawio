        <mxCell id="topics" value="Topicos principales&lt;br&gt;&lt;br&gt;&lt;b&gt;Sensores&lt;/b&gt;: sensors/dht22/*, sensors/door/state, sensors/mpu6050/*&lt;br&gt;&lt;b&gt;Estado&lt;/b&gt;: status/system, status/reason, status/components/*, status/last_will&lt;br&gt;&lt;b&gt;Control&lt;/b&gt;: control/mode&lt;br&gt;&lt;b&gt;Actuadores&lt;/b&gt;: actuators/fan/*, actuators/door_lock/state&lt;br&gt;&lt;b&gt;Seguridad&lt;/b&gt;: security/door/state, security/access/last_event&lt;br&gt;&lt;b&gt;Comandos&lt;/b&gt;: commands/mode/set, commands/door/*, commands/fan/*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7048e8;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_network">

        <mxCell id="door_state_machine" value="Maquina de estados de puerta&lt;br&gt;&lt;br&gt;door_secure&lt;br&gt;closed + locked -&gt; puede ser optimal&lt;br&gt;&lt;br&gt;door_unlocked_closed&lt;br&gt;closed + unlocked -&gt; warning&lt;br&gt;&lt;br&gt;door_open_authorized&lt;br&gt;open despues de unlock valido -&gt; warning&lt;br&gt;&lt;br&gt;door_open_forced&lt;br&gt;open sin unlock valido -&gt; critical&lt;br&gt;&lt;br&gt;door_lock_error&lt;br&gt;error bloqueo -&gt; critical" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#c92a2a;fontSize=12;align=left;verticalAlign=top;spacing=10;fontStyle=1;" vertex="1" parent="layer_security">

        <mxCell id="access_events" value="Eventos de acceso&lt;br&gt;&lt;br&gt;- none&lt;br&gt;- granted&lt;br&gt;- denied&lt;br&gt;- timeout&lt;br&gt;- forced_open&lt;br&gt;- manual_lock&lt;br&gt;&lt;br&gt;Se publican en:&lt;br&gt;security/access/last_event&lt;br&gt;&lt;br&gt;Se guardan en:&lt;br&gt;rack_security.access_event&lt;br&gt;rack_security.access_event_code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#495057;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="layer_security">
